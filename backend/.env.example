# Server
PORT=3000

# OpenAI (for Whisper STT + coaching LLM)
# 여기에 본인의 OpenAI API 키를 넣으세요
OPENAI_API_KEY=sk-proj-여기에-본인-API-키-입력

# Optional: use mock services when no API key (for dev)
# USE_MOCK_STT=false
# USE_MOCK_LLM=false

# ffmpeg가 PATH에 없을 때: bin 폴더 전체 경로
# Windows 예시: FFMPEG_PATH=C:\ffmpeg\bin
# Mac/Linux: 설치 시 PATH에 자동 등록되므로 보통 필요 없음
# FFMPEG_PATH=

# JWT 인증용 비밀 키 (아무 문자열이나 가능, 길고 복잡할수록 안전)
JWT_SECRET=your-secret-key-here
